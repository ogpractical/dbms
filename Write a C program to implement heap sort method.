❓ Q1) Write a C program to implement a hash table using open addressing with linear probing. perform the following operations.

Insert

Search

Display



---

✅ Solution

#include<stdio.h>

#define SIZE 10

int table[SIZE];

int hash(int key)
{
    return key % SIZE;
}

void insert(int key)
{
    int index = hash(key);

    while(table[index] != -1)
        index = (index + 1) % SIZE;

    table[index] = key;
}

void search(int key)
{
    int index = hash(key);
    int start = index;

    while(table[index] != -1)
    {
        if(table[index] == key)
        {
            printf("Key found at %d\n", index);
            return;
        }
        index = (index + 1) % SIZE;

        if(index == start)
            break;
    }

    printf("Key not found\n");
}

void display()
{
    for(int i = 0; i < SIZE; i++)
        printf("%d -> %d\n", i, table[i]);
}

int main()
{
    int choice, key;

    for(int i = 0; i < SIZE; i++)
        table[i] = -1;

    while(1)
    {
        printf("\n1.Insert 2.Search 3.Display 4.Exit\n");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:
                scanf("%d", &key);
                insert(key);
                break;
            case 2:
                scanf("%d", &key);
                search(key);
                break;
            case 3:
                display();
                break;
            case 4:
                return 0;
        }
    }
}


