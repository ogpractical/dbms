✅ Procedure

CREATE OR REPLACE PROCEDURE insert_project(
    pno INT,
    pname CHAR,
    ptype CHAR,
    dur INT
)
LANGUAGE plpgsql
AS $$
BEGIN
    INSERT INTO project VALUES(pno, pname, ptype, dur);
    RAISE NOTICE 'Record Inserted';
END;
$$;


