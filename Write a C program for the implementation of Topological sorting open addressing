❓ Write a trigger before insert/update on Doctor. Raise exception if charges are < 0.


---

✅ Trigger

CREATE OR REPLACE FUNCTION check_charges()
RETURNS TRIGGER AS
$$
BEGIN
    IF NEW.charges < 0 THEN
        RAISE EXCEPTION 'Charges cannot be negative';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_doc
BEFORE INSERT OR UPDATE ON doctor
FOR EACH ROW
EXECUTE FUNCTION check_charges();


