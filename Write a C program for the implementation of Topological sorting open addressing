❓ Q1) Write a C program for the implementation of Topological sorting.


---

✅ Solution

#include<stdio.h>

int adj[10][10], indeg[10], n;

void topological()
{
    int i, j, count = 0;

    while(count < n)
    {
        for(i = 0; i < n; i++)
        {
            if(indeg[i] == 0)
            {
                printf("%d ", i);
                indeg[i] = -1;

                for(j = 0; j < n; j++)
                {
                    if(adj[i][j] == 1)
                        indeg[j]--;
                }
                count++;
            }
        }
    }
}

int main()
{
    int i, j;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++)
    {
        indeg[i] = 0;
        for(j = 0; j < n; j++)
        {
            scanf("%d", &adj[i][j]);
            if(adj[i][j] == 1)
                indeg[j]++;
        }
    }

    printf("Topological order:\n");
    topological();

    return 0;
}


