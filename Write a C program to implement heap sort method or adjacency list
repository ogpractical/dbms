🔹 Q2) Write a stored function to accept eno as input parameter and count number of projects on which that employee is working.


---

✅ Function

CREATE OR REPLACE FUNCTION count_projects(empno INT)
RETURNS INT AS
$$
DECLARE
    total INT;
BEGIN
    SELECT COUNT(*) INTO total
    FROM project_employee
    WHERE eno = empno;

    RETURN total;
END;
$$ LANGUAGE plpgsql;


