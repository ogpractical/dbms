🔹 Q2) Write a stored function to display the ticket details of a train. (Accept train name as input parameter). Raise an exception in case of invalid train name.


---

✅ Function

CREATE OR REPLACE FUNCTION get_ticket_details(tname VARCHAR)
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
    cnt INT;
BEGIN
    SELECT COUNT(*) INTO cnt FROM train WHERE train_name = tname;

    IF cnt = 0 THEN
        RAISE EXCEPTION 'Invalid Train Name';
    END IF;

    FOR rec IN
        SELECT t.ticket_no, t.bogie_no, t.no_of_berths, t.ticket_amt, t.status
        FROM ticket t
        JOIN train tr ON t.train_no = tr.train_no
        WHERE tr.train_name = tname
    LOOP
        RAISE NOTICE 'Ticket: %, Bogie: %, Berths: %, Amount: %, Status: %',
                     rec.ticket_no, rec.bogie_no, rec.no_of_berths,
                     rec.ticket_amt, rec.status;
    END LOOP;
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT get_ticket_details('Rajdhani');


