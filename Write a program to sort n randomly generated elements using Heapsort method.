❓ Write a procedure that accept two numbers and display addition, subtraction and multiplication of two numbers.


---

✅ Procedure

CREATE OR REPLACE PROCEDURE operations(a INT, b INT)
LANGUAGE plpgsql
AS $$
BEGIN
    RAISE NOTICE 'Addition = %', a + b;
    RAISE NOTICE 'Subtraction = %', a - b;
    RAISE NOTICE 'Multiplication = %', a * b;
END;
$$;


