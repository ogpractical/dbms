❓ Write a trigger after insert on passenger to display message “Age above 5 will be charged full fare” if age of passenger is more than 5.


---

✅ Trigger

CREATE OR REPLACE FUNCTION check_age()
RETURNS TRIGGER AS
$$
BEGIN
    IF NEW.age > 5 THEN
        RAISE NOTICE 'Age above 5 will be charged full fare';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_passenger
AFTER INSERT ON passenger
FOR EACH ROW
EXECUTE FUNCTION check_age();


