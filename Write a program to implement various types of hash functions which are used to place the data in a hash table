🔷 Section I: Data Structures-II [15 Marks]

❓ Q1) Write a program to implement various types of hash functions which are used to place the data in a hash table

Division Method

Mid Square Method

Digit Folding Method


Accept n values from the user and display appropriate message in case of collision.


---

✅ Solution

#include<stdio.h>

#define SIZE 10

int table1[SIZE], table2[SIZE], table3[SIZE];

int division(int key)
{
    return key % SIZE;
}

int midsquare(int key)
{
    int sq = key * key;
    return (sq / 10) % SIZE;
}

int folding(int key)
{
    int sum = 0;
    while(key > 0)
    {
        sum += key % 100;
        key /= 100;
    }
    return sum % SIZE;
}

void insert(int table[], int index, int key)
{
    if(table[index] != -1)
        printf("Collision occurred for key %d at index %d\n", key, index);
    else
        table[index] = key;
}

int main()
{
    int n, key;

    for(int i = 0; i < SIZE; i++)
        table1[i] = table2[i] = table3[i] = -1;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    for(int i = 0; i < n; i++)
    {
        scanf("%d", &key);

        insert(table1, division(key), key);
        insert(table2, midsquare(key), key);
        insert(table3, folding(key), key);
    }

    return 0;
}


