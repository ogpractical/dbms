❓ Write a stored function to accept project name as input and print the names of employees working on the project. Raise an exception for an invalid project name.


---

✅ Function

CREATE OR REPLACE FUNCTION get_emp_by_project(pname VARCHAR)
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
    cnt INT;
BEGIN
    SELECT COUNT(*) INTO cnt FROM project WHERE p_name = pname;

    IF cnt = 0 THEN
        RAISE EXCEPTION 'Invalid Project Name';
    END IF;

    FOR rec IN
        SELECT e.e_name
        FROM employee e
        JOIN project_employee pe ON e.eno = pe.eno
        JOIN project p ON p.pno = pe.pno
        WHERE p.p_name = pname
    LOOP
        RAISE NOTICE 'Employee: %', rec.e_name;
    END LOOP;
END;
$$ LANGUAGE plpgsql;


