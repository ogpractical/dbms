❓ Q1) Write a C program that accepts the vertices and edges of a graph and store it as an adjacency list. Implement function to traverse the graph using Depth First Search (DFS) traversal.


---

✅ Solution

#include<stdio.h>
#include<stdlib.h>

struct node
{
    int vertex;
    struct node* next;
};

struct node* adj[10];
int visited[10];

void addEdge(int u, int v)
{
    struct node* n = (struct node*)malloc(sizeof(struct node));
    n->vertex = v;
    n->next = adj[u];
    adj[u] = n;
}

void dfs(int v)
{
    visited[v] = 1;
    printf("%d ", v);

    struct node* temp = adj[v];
    while(temp)
    {
        if(!visited[temp->vertex])
            dfs(temp->vertex);
        temp = temp->next;
    }
}

int main()
{
    int n, e, u, v, i, start;

    printf("Enter vertices: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        adj[i] = NULL;
        visited[i] = 0;
    }

    printf("Enter edges: ");
    scanf("%d", &e);

    for(i = 0; i < e; i++)
    {
        scanf("%d %d", &u, &v);
        addEdge(u, v);
        addEdge(v, u);
    }

    printf("Enter starting vertex: ");
    scanf("%d", &start);

    dfs(start);

    return 0;
}


