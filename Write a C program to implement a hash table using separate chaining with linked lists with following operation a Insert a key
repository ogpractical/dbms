🔹 Q2) Define a trigger before insert the record of driver if the age is not between 18 and 50, raise an error message “invalid entry”.


---

✅ Trigger

CREATE OR REPLACE FUNCTION check_age()
RETURNS TRIGGER AS
$$
BEGIN
    IF NEW.d_age < 18 OR NEW.d_age > 50 THEN
        RAISE EXCEPTION 'invalid entry';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_driver
BEFORE INSERT ON driver
FOR EACH ROW
EXECUTE FUNCTION check_age();


