❓ Write a stored function to accept the bus_no and date and print its allotted drivers. Raise an exception in case of invalid bus number.


---

✅ Function

CREATE OR REPLACE FUNCTION get_drivers(bno INT, d DATE)
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
    cnt INT;
BEGIN
    SELECT COUNT(*) INTO cnt FROM bus WHERE bus_no = bno;

    IF cnt = 0 THEN
        RAISE EXCEPTION 'Invalid Bus Number';
    END IF;

    FOR rec IN
        SELECT dr.driver_name
        FROM driver dr
        JOIN bus_driver bd ON dr.driver_no = bd.driver_no
        WHERE bd.bus_no = bno AND bd.duty_date = d
    LOOP
        RAISE NOTICE 'Driver: %', rec.driver_name;
    END LOOP;
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT get_drivers(101, '2024-01-01');


