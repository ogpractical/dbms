❓ Write a trigger before insert the record of student. If student number is less than or equal to zero give message “Invalid Number”.


---

✅ Trigger

CREATE OR REPLACE FUNCTION check_student()
RETURNS TRIGGER AS
$$
BEGIN
    IF NEW.s_no <= 0 THEN
        RAISE EXCEPTION 'Invalid Number';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_student
BEFORE INSERT ON student
FOR EACH ROW
EXECUTE FUNCTION check_student();


