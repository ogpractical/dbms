❓ Write a procedure accept two numbers from user and display minimum and maximum from two numbers. [5 marks]


---

✅ Procedure

CREATE OR REPLACE PROCEDURE find_min_max(a INT, b INT)
LANGUAGE plpgsql
AS $$
BEGIN
    IF a > b THEN
        RAISE NOTICE 'Max = %, Min = %', a, b;
    ELSE
        RAISE NOTICE 'Max = %, Min = %', b, a;
    END IF;
END;
$$;


