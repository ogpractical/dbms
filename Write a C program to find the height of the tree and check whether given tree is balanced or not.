❓ Write a trigger before inserting into movie table to check budget. Budget should be minimum 50 lakh. Display appropriate message.


---

✅ Trigger

CREATE OR REPLACE FUNCTION check_budget()
RETURNS TRIGGER AS
$$
BEGIN
    IF NEW.budget < 5000000 THEN
        RAISE EXCEPTION 'Budget must be at least 50 lakh';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_budget
BEFORE INSERT ON movies
FOR EACH ROW
EXECUTE FUNCTION check_budget();


