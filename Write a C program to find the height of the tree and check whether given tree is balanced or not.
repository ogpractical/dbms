❓ Q2) Using above Database Solve the following [10 Marks]

❓ Write a cursor to pass actor name as input parameter and return total number of movies in which given actor is acting.


---

✅ Step 1: Create Tables

CREATE TABLE movies (
    m_name VARCHAR(25) PRIMARY KEY,
    release_year INT,
    budget NUMERIC
);

CREATE TABLE actor (
    a_name CHAR(30),
    role CHAR(30),
    charges NUMERIC,
    a_address VARCHAR(30)
);

CREATE TABLE movie_actor (
    m_name VARCHAR(25),
    a_name CHAR(30),
    PRIMARY KEY (m_name, a_name),
    FOREIGN KEY (m_name) REFERENCES movies(m_name)
);


---

✅ Function using Cursor

CREATE OR REPLACE FUNCTION count_movies(actor_name VARCHAR)
RETURNS INT AS
$$
DECLARE
    total INT := 0;
    rec RECORD;
    cur CURSOR FOR
        SELECT m_name FROM movie_actor
        WHERE a_name = actor_name;
BEGIN
    FOR rec IN cur LOOP
        total := total + 1;
    END LOOP;

    RETURN total;
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT count_movies('Amitabh');


