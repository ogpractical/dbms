❓ Write a trigger before insert or update on rate field. If the rate is less than 50 then raise the appropriate exception.


---

✅ Trigger

CREATE OR REPLACE FUNCTION check_rate()
RETURNS TRIGGER AS
$$
BEGIN
    IF NEW.rate < 50 THEN
        RAISE EXCEPTION 'Rate must be >= 50';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_rate
BEFORE INSERT OR UPDATE ON item_supplier
FOR EACH ROW
EXECUTE FUNCTION check_rate();


