🔹 Q2) Write a stored function to display the book details written by author. (Accept Author name as input parameter). Raise an exception in case of invalid author name.


---

✅ Function

CREATE OR REPLACE FUNCTION get_books(aname VARCHAR)
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
    cnt INT;
BEGIN
    SELECT COUNT(*) INTO cnt FROM author WHERE a_name = aname;

    IF cnt = 0 THEN
        RAISE EXCEPTION 'Invalid Author Name';
    END IF;

    FOR rec IN
        SELECT b.b_name, b.pub_name, b.b_price
        FROM book b
        JOIN book_author ba ON b.b_no = ba.b_no
        JOIN author a ON a.a_no = ba.a_no
        WHERE a.a_name = aname
    LOOP
        RAISE NOTICE 'Book: %, Publisher: %, Price: %',
                     rec.b_name, rec.pub_name, rec.b_price;
    END LOOP;
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT get_books('Chetan');


