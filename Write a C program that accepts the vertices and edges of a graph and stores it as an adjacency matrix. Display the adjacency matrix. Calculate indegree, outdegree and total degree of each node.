❓ Write a trigger after insert on book to display message “prize is so high” if book price is more than 1000.


---

✅ Trigger

CREATE OR REPLACE FUNCTION check_price()
RETURNS TRIGGER AS
$$
BEGIN
    IF NEW.b_price > 1000 THEN
        RAISE NOTICE 'price is so high';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_book
AFTER INSERT ON book
FOR EACH ROW
EXECUTE FUNCTION check_price();


