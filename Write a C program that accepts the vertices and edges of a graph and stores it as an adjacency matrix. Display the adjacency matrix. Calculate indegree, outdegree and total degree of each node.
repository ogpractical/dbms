Author(a_no, a_name, qualification, address)
(M-M relationship)

Constraint: pub_name NOT NULL


---

🔹 Step 1: Create Tables

CREATE TABLE book (
    b_no INT PRIMARY KEY,
    b_name VARCHAR(20),
    pub_name VARCHAR(10) NOT NULL,
    b_price FLOAT
);

CREATE TABLE author (
    a_no INT PRIMARY KEY,
    a_name VARCHAR(20),
    qualification VARCHAR(15),
    address VARCHAR(15)
);

CREATE TABLE book_author (
    b_no INT,
    a_no INT,
    PRIMARY KEY (b_no, a_no),
    FOREIGN KEY (b_no) REFERENCES book(b_no),
    FOREIGN KEY (a_no) REFERENCES author(a_no)
);


