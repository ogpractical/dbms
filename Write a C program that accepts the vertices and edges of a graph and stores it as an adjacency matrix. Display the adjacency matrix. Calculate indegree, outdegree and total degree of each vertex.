🔁 OR

❓ Write a stored function to accept depot name and display driver details having age more than 50.

✅ Function

CREATE OR REPLACE FUNCTION get_driver_details(dep VARCHAR)
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
BEGIN
    FOR rec IN
        SELECT d.driver_name, d.d_age, d.salary
        FROM driver d
        JOIN bus_driver bd ON d.driver_no = bd.driver_no
        JOIN bus b ON b.bus_no = bd.bus_no
        WHERE b.depot_name = dep AND d.d_age > 50
    LOOP
        RAISE NOTICE 'Name: %, Age: %, Salary: %',
                     rec.driver_name, rec.d_age, rec.salary;
    END LOOP;
END;
$$ LANGUAGE plpgsql;

✅ Call

SELECT get_driver_details('Pune');


