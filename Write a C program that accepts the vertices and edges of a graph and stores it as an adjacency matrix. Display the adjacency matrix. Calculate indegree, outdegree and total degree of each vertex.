🔹 Q2) Write a stored function to accept the bus number and print driver name allotted to that bus.

✅ Function

CREATE OR REPLACE FUNCTION get_driver(bno INT)
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
BEGIN
    FOR rec IN
        SELECT d.driver_name
        FROM driver d
        JOIN bus_driver bd ON d.driver_no = bd.driver_no
        WHERE bd.bus_no = bno
    LOOP
        RAISE NOTICE 'Driver: %', rec.driver_name;
    END LOOP;
END;
$$ LANGUAGE plpgsql;

✅ Call

SELECT get_driver(101);


