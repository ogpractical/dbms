🔁 OR

❓ Q1) Write a C program which uses Binary search tree library and implements following function with recursion:

int copy(T)

int compare(T1, T2)


✅ Solution (Important functions)

node* copy(node* root)
{
    if(root == NULL) return NULL;

    node* newnode = create(root->data);
    newnode->left = copy(root->left);
    newnode->right = copy(root->right);

    return newnode;
}

int compare(node* t1, node* t2)
{
    if(t1 == NULL && t2 == NULL) return 1;
    if(t1 == NULL || t2 == NULL) return 0;

    if(t1->data != t2->data) return 0;

    return compare(t1->left, t2->left) &&
           compare(t1->right, t2->right);
}


