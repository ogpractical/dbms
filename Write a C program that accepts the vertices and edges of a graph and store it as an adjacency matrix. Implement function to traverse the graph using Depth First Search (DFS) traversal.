🔁 OR

❓ Q1) Write a C program to copy a Binary Search Tree and compares two binary search trees.


---

✅ Solution

#include<stdio.h>
#include<stdlib.h>

struct node
{
    int data;
    struct node *left, *right;
};

struct node* create(int val)
{
    struct node* n = (struct node*)malloc(sizeof(struct node));
    n->data = val;
    n->left = n->right = NULL;
    return n;
}

struct node* insert(struct node* root, int val)
{
    if(root == NULL)
        return create(val);

    if(val < root->data)
        root->left = insert(root->left, val);
    else
        root->right = insert(root->right, val);

    return root;
}

struct node* copyTree(struct node* root)
{
    if(root == NULL)
        return NULL;

    struct node* newNode = create(root->data);
    newNode->left = copyTree(root->left);
    newNode->right = copyTree(root->right);

    return newNode;
}

int compare(struct node* t1, struct node* t2)
{
    if(t1 == NULL && t2 == NULL)
        return 1;

    if(t1 && t2)
        return (t1->data == t2->data &&
                compare(t1->left, t2->left) &&
                compare(t1->right, t2->right));

    return 0;
}

int main()
{
    struct node *root = NULL, *copy = NULL;
    int n, val, i;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        scanf("%d", &val);
        root = insert(root, val);
    }

    copy = copyTree(root);

    if(compare(root, copy))
        printf("Trees are identical\n");
    else
        printf("Trees are not identical\n");

    return 0;
}


