🔹 Step 1: Create Tables

CREATE TABLE item (
    itemno INT PRIMARY KEY,
    itemname VARCHAR(20),
    quantity INT
);

CREATE TABLE supplier (
    supplierno INT PRIMARY KEY,
    suppliername VARCHAR(20),
    city VARCHAR(20)
);

