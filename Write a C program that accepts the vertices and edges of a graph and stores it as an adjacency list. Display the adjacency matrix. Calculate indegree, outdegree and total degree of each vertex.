❓ Write a trigger after insert on an employee record. Display appropriate message when the record is inserted.


---

✅ Trigger

CREATE OR REPLACE FUNCTION after_insert_emp()
RETURNS TRIGGER AS
$$
BEGIN
    RAISE NOTICE 'Employee record inserted successfully';
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_after_emp
AFTER INSERT ON employee
FOR EACH ROW
EXECUTE FUNCTION after_insert_emp();


