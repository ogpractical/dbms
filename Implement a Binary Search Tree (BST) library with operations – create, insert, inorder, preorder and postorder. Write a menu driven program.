🔹 Q2) Write a stored function to count number of teachers having experience > 10 years


---

✅ Function

CREATE OR REPLACE FUNCTION count_teachers()
RETURNS INT AS
$$
DECLARE
    total INT;
BEGIN
    SELECT COUNT(*) INTO total
    FROM teacher
    WHERE experience > 10;

    RETURN total;
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT count_teachers();


