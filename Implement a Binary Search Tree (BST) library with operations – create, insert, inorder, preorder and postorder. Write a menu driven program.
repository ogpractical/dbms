❓ Write a trigger before insert on student. If roll_no <= 0, display error.


---

✅ Trigger

CREATE OR REPLACE FUNCTION check_roll()
RETURNS TRIGGER AS
$$
BEGIN
    IF NEW.roll_no <= 0 THEN
        RAISE EXCEPTION 'Invalid Roll Number';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_student
BEFORE INSERT ON student
FOR EACH ROW
EXECUTE FUNCTION check_roll();


