🔹 Q2) Write a function to accept department name and display the maximum salary of an employee in that department.


---

✅ Function

CREATE OR REPLACE FUNCTION max_salary(dept_name VARCHAR)
RETURNS MONEY AS
$$
DECLARE
    max_sal MONEY;
BEGIN
    SELECT MAX(e.salary) INTO max_sal
    FROM employee e
    JOIN department d ON e.dno = d.dno
    WHERE d.dname = dept_name;

    RETURN max_sal;
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT max_salary('Sales');


