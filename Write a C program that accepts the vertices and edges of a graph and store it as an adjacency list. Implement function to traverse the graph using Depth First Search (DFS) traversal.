❓ Write a procedure to accept a number and display multiplication table of a number.


---

✅ Procedure

CREATE OR REPLACE PROCEDURE multiplication_table(n INT)
LANGUAGE plpgsql
AS $$
DECLARE
    i INT;
BEGIN
    FOR i IN 1..10 LOOP
        RAISE NOTICE '% x % = %', n, i, n*i;
    END LOOP;
END;
$$;


