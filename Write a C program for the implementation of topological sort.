🔹 Q2) Write a function using cursor which accepts city name as input and prints the details of all customers in that city.


---

✅ Function

CREATE OR REPLACE FUNCTION get_customers(city_name VARCHAR)
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
BEGIN
    FOR rec IN
        SELECT * FROM customer
        WHERE city = city_name
    LOOP
        RAISE NOTICE 'Cno: %, Name: %, City: %',
                     rec.cno, rec.cname, rec.city;
    END LOOP;
END;
$$ LANGUAGE plpgsql;


