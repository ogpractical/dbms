❓ Write a trigger before deleting a person's record. Display message “person record is being deleted”.


---

✅ Trigger

CREATE OR REPLACE FUNCTION before_delete_person()
RETURNS TRIGGER AS
$$
BEGIN
    RAISE NOTICE 'Person record is being deleted';
    RETURN OLD;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_person_delete
BEFORE DELETE ON person
FOR EACH ROW
EXECUTE FUNCTION before_delete_person();


