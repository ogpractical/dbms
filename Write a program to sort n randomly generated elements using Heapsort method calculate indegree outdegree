🔹 Q2) Write a cursor to display the names of persons living in urban area.


---

✅ Cursor (Function)

CREATE OR REPLACE FUNCTION urban_people()
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
BEGIN
    FOR rec IN
        SELECT p.pname
        FROM person p
        JOIN area a ON p.aid = a.aid
        WHERE a.area_type = 'urban'
    LOOP
        RAISE NOTICE 'Person: %', rec.pname;
    END LOOP;
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT urban_people();


