🔹 Q2) Write a stored function using cursors, to accept class and display details of students of that class.


---

✅ Function

CREATE OR REPLACE FUNCTION student_by_class(cls VARCHAR)
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
BEGIN
    FOR rec IN
        SELECT * FROM student WHERE class = cls
    LOOP
        RAISE NOTICE 'Roll: %, Name: %, Class: %',
                     rec.rollno, rec.name, rec.class;
    END LOOP;
END;
$$ LANGUAGE plpgsql;


