❓ Q1) Write a C program that accepts the vertices and edges of a graph and store it as an adjacency matrix. Implement function to traverse the graph using Breadth First Search (BFS) traversal.


---

✅ Solution

#include<stdio.h>

int adj[10][10], visited[10], queue[10];
int front = -1, rear = -1, n;

void enqueue(int x)
{
    if(rear == -1)
        front = rear = 0;
    else
        rear++;
    queue[rear] = x;
}

int dequeue()
{
    int x = queue[front];
    if(front == rear)
        front = rear = -1;
    else
        front++;
    return x;
}

void bfs(int v)
{
    int i;
    enqueue(v);
    visited[v] = 1;

    while(front != -1)
    {
        v = dequeue();
        printf("%d ", v);

        for(i = 0; i < n; i++)
        {
            if(adj[v][i] == 1 && visited[i] == 0)
            {
                enqueue(i);
                visited[i] = 1;
            }
        }
    }
}

int main()
{
    int i, j, e, u, v;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        visited[i] = 0;
        for(j = 0; j < n; j++)
            adj[i][j] = 0;
    }

    printf("Enter number of edges: ");
    scanf("%d", &e);

    for(i = 0; i < e; i++)
    {
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;
        adj[v][u] = 1;
    }

    printf("BFS Traversal:\n");
    bfs(0);

    return 0;
}


