❓ Write a stored function using cursors, to calculate total marks of each student and display it.


---

✅ Function

CREATE OR REPLACE FUNCTION total_marks()
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
BEGIN
    FOR rec IN
        SELECT rollno, SUM(marks_scored) AS total
        FROM student_subject
        GROUP BY rollno
    LOOP
        RAISE NOTICE 'Roll No: %, Total Marks: %',
                     rec.rollno, rec.total;
    END LOOP;
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT total_marks();


