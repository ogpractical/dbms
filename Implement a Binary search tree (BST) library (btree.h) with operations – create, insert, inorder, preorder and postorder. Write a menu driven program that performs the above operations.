🔹 Q1 (Option 2): Graph using Adjacency Matrix + Degree

#include<stdio.h>

int main() {
    int n, i, j;
    int adj[10][10];

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for(i=0;i<n;i++) {
        for(j=0;j<n;j++) {
            scanf("%d",&adj[i][j]);
        }
    }

    printf("\nAdjacency Matrix:\n");
    for(i=0;i<n;i++) {
        for(j=0;j<n;j++) {
            printf("%d ", adj[i][j]);
        }
        printf("\n");
    }

    for(i=0;i<n;i++) {
        int indegree=0, outdegree=0;

        for(j=0;j<n;j++) {
            outdegree += adj[i][j];
            indegree += adj[j][i];
        }

        printf("Vertex %d: Indegree=%d Outdegree=%d Total=%d\n",
               i, indegree, outdegree, indegree+outdegree);
    }

    return 0;
}


