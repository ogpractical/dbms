🔹 Q2 (2) Procedure (Addition, Subtraction, Multiplication)

DELIMITER $$

CREATE PROCEDURE operations(IN a INT, IN b INT, IN c INT)
BEGIN
    SELECT (a + b + c) AS Addition,
           (a - b - c) AS Subtraction,
           (a * b * c) AS Multiplication;
END $$

DELIMITER ;
