🔹 Q2 (1) Stored Function

DELIMITER $$

CREATE FUNCTION count_projects(eid INT)
RETURNS INT
DETERMINISTIC
BEGIN
    DECLARE total INT;
    SELECT COUNT(*) INTO total
    FROM Works_On
    WHERE eno = eid;

    RETURN total;
END $$

DELIMITER ;


