✅ Procedure

CREATE OR REPLACE PROCEDURE insert_person(pn VARCHAR, pc VARCHAR)
LANGUAGE plpgsql
AS $$
BEGIN
    INSERT INTO person(pname, pcity)
    VALUES (pn, pc);

    RAISE NOTICE 'Record inserted';
END;
$$;


