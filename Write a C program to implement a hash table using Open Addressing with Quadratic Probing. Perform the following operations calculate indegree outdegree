❓ Write a trigger before deleting company record. Display appropriate message.


---

✅ Trigger

CREATE OR REPLACE FUNCTION before_delete_company()
RETURNS TRIGGER AS
$$
BEGIN
    RAISE NOTICE 'Company record is being deleted';
    RETURN OLD;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_company_delete
BEFORE DELETE ON company
FOR EACH ROW
EXECUTE FUNCTION before_delete_company();


