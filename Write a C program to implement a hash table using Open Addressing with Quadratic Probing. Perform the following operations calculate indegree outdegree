🔹 Q2) Write a stored function to update the share_values by 20% for Person.


---

✅ Function

CREATE OR REPLACE FUNCTION update_share(p_name VARCHAR)
RETURNS VOID AS
$$
BEGIN
    UPDATE company
    SET share_value = share_value * 1.2
    WHERE name IN (
        SELECT name
        FROM company_person
        WHERE pname = p_name
    );

    RAISE NOTICE 'Share values updated by 20%';
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT update_share('Rahul');


