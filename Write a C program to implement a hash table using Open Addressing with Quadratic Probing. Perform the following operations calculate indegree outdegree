❓ Q1) Write a C program that accepts the vertices and edges of a graph and stores it as an adjacency list. Display adjacency matrix. Calculate indegree, outdegree and total degree.


---

✅ Solution

#include<stdio.h>
#include<stdlib.h>

struct node
{
    int vertex;
    struct node* next;
};

struct node* adj[10];
int matrix[10][10], indeg[10], outdeg[10];

void addEdge(int u, int v)
{
    struct node* n = (struct node*)malloc(sizeof(struct node));
    n->vertex = v;
    n->next = adj[u];
    adj[u] = n;

    matrix[u][v] = 1;
    outdeg[u]++;
    indeg[v]++;
}

int main()
{
    int n, e, u, v, i, j;

    printf("Enter vertices: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        adj[i] = NULL;
        indeg[i] = outdeg[i] = 0;
        for(j = 0; j < n; j++)
            matrix[i][j] = 0;
    }

    printf("Enter edges: ");
    scanf("%d", &e);

    for(i = 0; i < e; i++)
    {
        scanf("%d %d", &u, &v);
        addEdge(u, v);
    }

    printf("\nAdjacency Matrix:\n");
    for(i = 0; i < n; i++)
    {
        for(j = 0; j < n; j++)
            printf("%d ", matrix[i][j]);
        printf("\n");
    }

    for(i = 0; i < n; i++)
    {
        printf("\nVertex %d: Indegree=%d Outdegree=%d Total=%d",
               i, indeg[i], outdeg[i], indeg[i]+outdeg[i]);
    }

    return 0;
}


