🔷 Section I: Data Structures-II [15 Marks]

❓ Q1) Write a C program to implement a hash table using Open Addressing with Quadratic Probing. Perform the following operations.

Insert

Delete

Display



---

✅ Solution

#include<stdio.h>

#define SIZE 10

int table[SIZE];

int hash(int key)
{
    return key % SIZE;
}

void insert(int key)
{
    int index = hash(key);
    int i = 0;

    while(table[(index + i*i) % SIZE] != -1 && table[(index + i*i) % SIZE] != -2)
        i++;

    table[(index + i*i) % SIZE] = key;
}

void delete(int key)
{
    int index = hash(key);
    int i = 0;

    while(table[(index + i*i) % SIZE] != -1 && i < SIZE)
    {
        if(table[(index + i*i) % SIZE] == key)
        {
            table[(index + i*i) % SIZE] = -2; // mark deleted
            printf("Deleted\n");
            return;
        }
        i++;
    }

    printf("Key not found\n");
}

void display()
{
    for(int i = 0; i < SIZE; i++)
        printf("%d -> %d\n", i, table[i]);
}

int main()
{
    int i, ch, key;

    for(i = 0; i < SIZE; i++)
        table[i] = -1;

    while(1)
    {
        printf("\n1.Insert 2.Delete 3.Display 4.Exit\n");
        scanf("%d", &ch);

        switch(ch)
        {
            case 1:
                scanf("%d", &key);
                insert(key);
                break;
            case 2:
                scanf("%d", &key);
                delete(key);
                break;
            case 3:
                display();
                break;
            case 4:
                return 0;
        }
    }
}


