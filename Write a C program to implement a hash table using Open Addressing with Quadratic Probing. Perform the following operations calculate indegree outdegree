    pname VARCHAR(30) PRIMARY KEY,
    pcity VARCHAR(20)
);

CREATE TABLE company_person (
    name VARCHAR(30),
    pname VARCHAR(30),
    no_of_shares INT,
    PRIMARY KEY (name, pname),
    FOREIGN KEY (name) REFERENCES company(name),
    FOREIGN KEY (pname) REFERENCES person(pname)
);


