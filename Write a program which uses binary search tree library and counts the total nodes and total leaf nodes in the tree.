❓ Define a trigger before deleting a student record from student table. Raise a notice and display message “student record is being deleted”.


---

✅ Trigger

CREATE OR REPLACE FUNCTION before_delete_student()
RETURNS TRIGGER AS
$$
BEGIN
    RAISE NOTICE 'student record is being deleted';
    RETURN OLD;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_delete
BEFORE DELETE ON student
FOR EACH ROW
EXECUTE FUNCTION before_delete_student();


