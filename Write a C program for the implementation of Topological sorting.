🔹 Q2) Write a stored function using cursor to count the number of customers of particular branch. (Accept branch name as input parameter).


---

✅ Function

CREATE OR REPLACE FUNCTION count_customers(bname VARCHAR)
RETURNS INT AS
$$
DECLARE
    total INT := 0;
    rec RECORD;
BEGIN
    FOR rec IN
        SELECT cno
        FROM ternary_relation t
        JOIN branch b ON t.br_id = b.br_id
        WHERE b.br_name = bname
    LOOP
        total := total + 1;
    END LOOP;

    RETURN total;
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT count_customers('SBI');


