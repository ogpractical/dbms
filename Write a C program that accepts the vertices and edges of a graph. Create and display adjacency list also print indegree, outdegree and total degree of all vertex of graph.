❓ Q1) Write a C program to find mirror image of given Binary Search Tree and compares two Binary Search Trees.


---

✅ Solution

#include<stdio.h>
#include<stdlib.h>

struct node
{
    int data;
    struct node *left, *right;
};

struct node* create(int val)
{
    struct node* n = (struct node*)malloc(sizeof(struct node));
    n->data = val;
    n->left = n->right = NULL;
    return n;
}

struct node* insert(struct node* root, int val)
{
    if(root == NULL)
        return create(val);

    if(val < root->data)
        root->left = insert(root->left, val);
    else
        root->right = insert(root->right, val);

    return root;
}

struct node* mirror(struct node* root)
{
    if(root == NULL)
        return NULL;

    struct node* temp = root->left;
    root->left = mirror(root->right);
    root->right = mirror(temp);

    return root;
}

int compare(struct node* r1, struct node* r2)
{
    if(r1 == NULL && r2 == NULL)
        return 1;

    if(r1 == NULL || r2 == NULL)
        return 0;

    return (r1->data == r2->data) &&
           compare(r1->left, r2->left) &&
           compare(r1->right, r2->right);
}

void inorder(struct node* root)
{
    if(root)
    {
        inorder(root->left);
        printf("%d ", root->data);
        inorder(root->right);
    }
}

int main()
{
    struct node *t1 = NULL, *t2 = NULL;
    int n, val, i;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        scanf("%d", &val);
        t1 = insert(t1, val);
        t2 = insert(t2, val);
    }

    printf("Original Tree: ");
    inorder(t1);

    t2 = mirror(t2);

    printf("\nMirror Tree: ");
    inorder(t2);

    if(compare(t1, t2))
        printf("\nTrees are same");
    else
        printf("\nTrees are different");

    return 0;
}


