❓ Write a function using cursor which accepts a name of student and returns the total no of prizes won by that student in the year 2020.


---

✅ Function

CREATE OR REPLACE FUNCTION total_prizes(sname VARCHAR)
RETURNS INT AS
$$
DECLARE
    total INT := 0;
    rec RECORD;
BEGIN
    FOR rec IN
        SELECT sc.prize
        FROM student s
        JOIN student_competition sc ON s.sreg_no = sc.sreg_no
        WHERE s.name = sname AND sc.year = 2020
    LOOP
        total := total + rec.prize;
    END LOOP;

    RETURN total;
END;
$$ LANGUAGE plpgsql;


