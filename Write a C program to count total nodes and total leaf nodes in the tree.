❓ Write a trigger before insert/update on Driver. Raise exception if driver age is < 21.


---

✅ Trigger

CREATE OR REPLACE FUNCTION check_age()
RETURNS TRIGGER AS
$$
BEGIN
    IF NEW.d_age < 21 THEN
        RAISE EXCEPTION 'Driver age must be >= 21';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_driver
BEFORE INSERT OR UPDATE ON driver
FOR EACH ROW
EXECUTE FUNCTION check_age();


