🔹 Q2) Write a cursor which accepts the driver name and prints the details of all cars that this driver has driven, if the driver name is invalid, print an appropriate message.


---

✅ Cursor Function

CREATE OR REPLACE FUNCTION get_cars(dname VARCHAR)
RETURNS VOID AS
$$
DECLARE
    rec RECORD;
    cnt INT;
BEGIN
    SELECT COUNT(*) INTO cnt FROM driver WHERE driver_name = dname;

    IF cnt = 0 THEN
        RAISE NOTICE 'Invalid Driver Name';
        RETURN;
    END IF;

    FOR rec IN
        SELECT c.*
        FROM car c
        JOIN car_driver cd ON c.c_no = cd.c_no
        JOIN driver d ON d.driver_no = cd.driver_no
        WHERE d.driver_name = dname
    LOOP
        RAISE NOTICE 'Car: %, Owner: %, Model: %, Color: %',
                     rec.c_no, rec.owner, rec.model, rec.color;
    END LOOP;
END;
$$ LANGUAGE plpgsql;


---

✅ Call

SELECT get_cars('Rahul');


