❓ Q1) Write a C program for the Implementation of topological sorting algorithm.


---

✅ Solution (Topological Sort using DFS)

#include<stdio.h>

int adj[10][10], visited[10], stack[10];
int n, top = -1;

void dfs(int v)
{
    visited[v] = 1;

    for(int i = 0; i < n; i++)
    {
        if(adj[v][i] == 1 && !visited[i])
            dfs(i);
    }

    stack[++top] = v;
}

int main()
{
    int i, j;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++)
            scanf("%d", &adj[i][j]);

    for(i = 0; i < n; i++)
        visited[i] = 0;

    for(i = 0; i < n; i++)
        if(!visited[i])
            dfs(i);

    printf("Topological Order: ");
    for(i = top; i >= 0; i--)
        printf("%d ", stack[i]);

    return 0;
}


