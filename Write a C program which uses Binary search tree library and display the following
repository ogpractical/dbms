❓ Write a procedure to accept three numbers from user and find maximum and minimum from it. [5 marks]


---

✅ Procedure

CREATE OR REPLACE PROCEDURE max_min(a INT, b INT, c INT)
LANGUAGE plpgsql
AS $$
DECLARE
    max_val INT;
    min_val INT;
BEGIN
    max_val := GREATEST(a, b, c);
    min_val := LEAST(a, b, c);

    RAISE NOTICE 'Maximum = %, Minimum = %', max_val, min_val;
END;
$$;


---

✅ Call

CALL max_min(10, 20, 5);


